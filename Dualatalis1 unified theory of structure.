\subsection{Typing Rules}

\paragraph{Rule Typing.}
If $r : \Sigma \to \Sigma^{*}$, then:


\[
  r : \texttt{Rule}(\Sigma).
\]



\paragraph{Phi Typing.}
If $r_{\mathrm{g}}$ and $r_{\mathrm{r}}$ are rules on $\Sigma$, then:


\[
  \varphi = r_{\mathrm{r}} \circ r_{\mathrm{g}}
  : \texttt{Phi}(\Sigma).
\]



\paragraph{Universe Typing.}
If $w_0 \in \Sigma^{*}$ and $\varphi$ is defined on $\Sigma$, then:


\[
  (\Sigma, w_0, \varphi) : \texttt{Universe}.
\]



