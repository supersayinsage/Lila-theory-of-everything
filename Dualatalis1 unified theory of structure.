\section{Formal Grammar (BNF)}

This section defines the complete grammar of the Dualatalis language
using Backus–Naur Form (BNF). The grammar specifies all syntactic
constructs: alphabets, rules, universes, operators, observables,
iteration, and structural queries.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Lexical Structure}

<letter> ::= A | B | C | ... | Z | a | b | ... | z
<digit>  ::= 0 | 1 | ... | 9
<symbol> ::= <letter> | <digit> | '_' | '-'

<identifier> ::= <letter> { <symbol> }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Program Structure}

<program> ::= { <declaration> }

<declaration> ::= <alphabet_decl>
                | <rule_decl>
                | <phi_decl>
                | <universe_decl>
                | <observable_decl>
                | <iteration_stmt>
                | <query_stmt>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Alphabet Declaration}

<alphabet_decl> ::= "alphabet" "{" <symbol_list> "}"

<symbol_list> ::= <identifier> { "," <identifier> }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Word Literal}

<word_literal> ::= <identifier> { <identifier> }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Rule Declaration}

<rule_decl> ::= "rule" <identifier> "{" { <rule_line> } "}"

<rule_line> ::= <identifier> "->" <word_literal>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Phi Declaration}

<phi_decl> ::= "phi" "=" <phi_expr>

<phi_expr> ::= <identifier>
             | <identifier> "∘" <identifier>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Universe Declaration}

<universe_decl> ::= "universe" <identifier> "{"
                      <universe_body>
                    "}"

<universe_body> ::= <alphabet_decl>
                  | <initial_decl>
                  | <rule_decl>
                  | <phi_decl>
                  | <universe_body> <universe_body>

<initial_decl> ::= "initial" <word_literal>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Iteration Statement}

<iteration_stmt> ::= "iterate" <identifier> "." "phi"
                     "for" <number>

<number> ::= <digit> { <digit> }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Observable Declaration}

<observable_decl> ::= "observable" <identifier> "(" <param_list> ")"
                      "=" <expr>

<param_list> ::= <identifier> { "," <identifier> }

<expr> ::= <identifier>
         | <expr> <operator> <expr>
         | <function_call>

<operator> ::= "+" | "-" | "*" | "/" | "==" | "!=" | "<" | ">"

<function_call> ::= <identifier> "(" <arg_list> ")"

<arg_list> ::= <expr> { "," <expr> }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Query Statements}

<query_stmt> ::= "fixed_points" "of" <identifier>
               | "cycles" "of" <identifier>
               | "entropy" "of" <identifier>
               | "spectrum" "of" <identifier>
               | "homotopy" "of" <identifier>
               | "classify" <identifier>

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Structural Operators}

<struct_op> ::= "length"
              | "count"
              | "subword"
              | "replace"

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Subshift Operators}

<subshift_op> ::= "language"
                | "forbidden"
                | "sft"
                | "sofic"

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Spectral Operators}

<spectral_op> ::= "koopman"
                | "eigenvalues"
                | "eigenfunctions"
                | "spectral_radius"
                | "mode_decompose"

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{Homotopy Operators}

<homotopy_op> ::= "rewrite_graph"
                | "paths"
                | "homotopy"
                | "hocolim"
                | "homology"

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\subsection{RG Operators}

<rg_op> ::= "coarse_grain"
          | "rescale"
          | "rg_step"
          | "rg_flow"
          | "rg_fixed_points"

