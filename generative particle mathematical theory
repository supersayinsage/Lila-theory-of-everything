\begin{abstract}
We formulate a self-contained theory of a universal scalar excitation---the
\emph{generative particle}---whose field drives the formation, stabilization,
and repair of structure across domains (physical, biological, informational,
and geometric). The theory is constructed as a minimal field-theoretic
framework with a scalar generative field, a structural Lagrangian, a
well-defined particle excitation, and falsifiable predictions. We then
specialize to a biological effective theory (GPT-B), where the same field
governs stem-cell organization and tissue regeneration, and derive concrete,
testable signatures.
\end{abstract}

\section{Ontological Postulate}

We postulate the existence of a single fundamental scalar field
\begin{equation}
  \mathcal{G}(x) : X \to \mathbb{R},
\end{equation}
defined over a configuration space $X$ of structures. The domain $X$ may
represent:
\begin{itemize}
  \item physical spacetime,
  \item biological tissue or cellular configurations,
  \item network topologies,
  \item geometric manifolds,
  \item informational or dependency graphs.
\end{itemize}

The \emph{generative particle} is defined as the lowest-energy excitation of
$\mathcal{G}$:
\begin{equation}
  \psi \equiv \text{quantum of } \mathcal{G}.
\end{equation}
This particle is a scalar boson (spin $0$) and is the only primitive object
introduced by the theory.

\section{Structural Lagrangian and Dynamics}

Let $G$ denote a structural configuration (graph, manifold, tissue, etc.).
We define a structural Lagrangian
\begin{equation}
  L[\mathcal{G}, G]
  = \alpha\,\Phi(G) - \beta\,S(G) + \gamma\,\mathcal{G}(G),
  \label{eq:L_struct}
\end{equation}
where:
\begin{itemize}
  \item $\Phi(G)$ is a \emph{stability functional} (e.g.\ algebraic
        connectivity, curvature, elastic energy),
  \item $S(G)$ is a \emph{structural entropy} (e.g.\ spatial or topological
        disorder),
  \item $\mathcal{G}(G)$ is the generative potential evaluated on $G$,
  \item $\alpha, \beta, \gamma > 0$ are constants.
\end{itemize}

The structural dynamics are defined by gradient flow in configuration space:
\begin{equation}
  \frac{dG}{dt}
  = -\nabla_G L[\mathcal{G}, G]
  = -\alpha\,\nabla_G \Phi(G)
    + \beta\,\nabla_G S(G)
    - \gamma\,\nabla_G \mathcal{G}(G).
  \label{eq:struct_dynamics}
\end{equation}
This encodes a competition between:
\begin{itemize}
  \item stability maximization ($+\Phi$),
  \item entropy reduction ($-S$),
  \item attraction to generative configurations ($+\mathcal{G}$).
\end{itemize}

\section{Field-Theoretic Action and Potential}

We promote $\mathcal{G}(x)$ to a dynamical field with standard kinetic term.
The action in a $d$-dimensional spacetime (or effective domain) is
\begin{equation}
  S = \int d^dx\,
  \left[
    \frac{1}{2} (\partial_\mu \mathcal{G})(\partial^\mu \mathcal{G})
    - V(\mathcal{G})
    + \alpha\,\Phi(G) - \beta\,S(G)
  \right],
  \label{eq:action}
\end{equation}
where $V(\mathcal{G})$ is a scalar potential. The minimal stable choice is
\begin{equation}
  V(\mathcal{G}) =
  \frac{1}{2} m_\psi^2 \mathcal{G}^2
  + \frac{\lambda}{4}\mathcal{G}^4,
  \label{eq:potential}
\end{equation}
with $m_\psi$ the mass of the generative particle and $\lambda > 0$ a
self-interaction coupling.

\section{Particle Definition and Mass}

Linearizing the structural Lagrangian \eqref{eq:L_struct} around a stable
configuration $G_0$, we define the Hessian
\begin{equation}
  H = \left.\frac{\partial^2 L}{\partial G^2}\right|_{G_0}.
\end{equation}
Let $\lambda_{\min} > 0$ be the smallest positive eigenvalue of $H$. We
identify the mass of the generative particle as
\begin{equation}
  m_\psi = \lambda_{\min},
\end{equation}
and the corresponding eigenmode as the structural profile of $\psi$:
\begin{equation}
  \psi \leftrightarrow \text{eigenmode associated with } \lambda_{\min}.
\end{equation}

\section{Symmetry and Generative Charge}

Let $\mathcal{S}$ be the symmetry group of the configuration space $X$ (e.g.\
graph automorphisms, isometries, gauge symmetries). We require
\begin{equation}
  L[\mathcal{G}, G] = L[\mathcal{G}, \sigma(G)], \quad \forall \sigma \in \mathcal{S}.
\end{equation}
The generative field transforms as a scalar under $\mathcal{S}$.

A natural conserved quantity (``generative charge'') is
\begin{equation}
  Q = \alpha\,\Phi(G) - \beta\,S(G),
\end{equation}
which remains invariant under the dynamics when the symmetry is exact.

\section{Quantization and Propagator}

Canonical quantization of $\mathcal{G}(x)$ yields
\begin{equation}
  \mathcal{G}(x) =
  \int \frac{d^3k}{(2\pi)^3 2\omega_k}
  \left(
    a_{\bm{k}} e^{-ikx} + a_{\bm{k}}^\dagger e^{ikx}
  \right),
\end{equation}
with $\omega_k = \sqrt{\bm{k}^2 + m_\psi^2}$ and creation/annihilation
operators $a_{\bm{k}}^\dagger, a_{\bm{k}}$.

The propagator in momentum space is
\begin{equation}
  D(k) = \frac{1}{k^2 - m_\psi^2 + i\epsilon},
\end{equation}
which governs how generative influence propagates through the domain.

\section{Interaction with Structure}

We introduce a universal interaction term
\begin{equation}
  \mathcal{L}_{\text{int}} = g\,\mathcal{G}(x)\,J(x),
\end{equation}
where $g$ is a coupling constant and $J(x)$ is a structural current, defined
appropriately for the domain:
\begin{itemize}
  \item in networks: $J \sim \partial \Phi / \partial G$,
  \item in tissues: $J \sim \nabla \cdot \text{order}$,
  \item in geometry: $J \sim \nabla \cdot (\text{curvature})$.
\end{itemize}

\section{Falsifiable Prediction (Domain-Independent)}

For any system whose structure $G(t)$ evolves under the generative dynamics
\eqref{eq:struct_dynamics}, we define a stability functional $\Phi(G)$ and
compare its evolution to a baseline random or purely biochemical/mechanical
model. The core prediction of Generative Particle Theory (GPT) is:
\begin{equation}
  \frac{d\,\Phi(G)}{dt}
  >
  \left(\frac{d\,\Phi(G)}{dt}\right)_{\text{random}},
\end{equation}
i.e.\ structure stabilizes and organizes faster than random or known
non-generative models allow.

