\section{The Human Traveler: Real, Data-Grounded}

From this point forward, the mathematics leaves analogy behind and becomes \textbf{empirically testable}.

\subsection{Human State Variables}

Let a human traveler be defined by:

\[
\begin{aligned}
\mathbf{P}(t) &\in \mathbb{R}^5 \quad &\text{(Perceptual state)} \\
\mathbf{M}(t) &\in \mathbb{R}^5 \quad &\text{(Memory, weighted average of heard songs)} \\
\alpha(t) &\in [0,1] \quad &\text{(Attention)} \\
\phi(t) &\in [0,1] \quad &\text{(Fatigue)} \\
\mathbf{w}(t) &\in \mathbb{R}^5 \quad &\text{(Preference vector, } \sum w_i = 1\text{)} \\
\mathcal{E}(t) &\in [0,10] \quad &\text{(Uncapturable emotion, input by human)}
\end{aligned}
\]

\subsection{Perception Equation}

Let $\beta(t) = 1 - \alpha(t) \phi(t) \in [0,1]$. Then:

\[
\boxed{\mathbf{P}(t) = \beta(t) \cdot \mathbf{T}_{s(t)} + \big(1 - \beta(t)\big) \cdot \mathbf{M}(t-1)}
\]

Interpretation: High attention + low fatigue ($\beta \approx 1$) means hearing the song as it is. Low attention or high fatigue ($\beta \ll 1$) means hearing through the haze of memory.

\subsection{Memory Update}

\[
\boxed{\mathbf{M}(t) = \gamma \cdot \mathbf{M}(t-1) + (1-\gamma) \cdot \mathbf{T}_{s(t)}}
\]

where $\gamma \in [0,1]$ is memory decay rate. $\gamma \approx 0.85$ gives a long memory; songs blend together over time.

\subsection{Attention Dynamics}

Attention changes based on surprise and taste alignment:

\[
\boxed{\alpha(t+1) = \alpha(t) + \lambda \cdot \big( \mathcal{S}(t) \cdot \mathcal{U}(t) - \alpha(t) \big)}
\]

where:

\[
\mathcal{S}(t) = \|\mathbf{T}_{s(t)} - \mathbf{M}(t-1)\| \quad \text{(Surprise)}
\]
\[
\mathcal{U}(t) = \langle \mathbf{w}(t), \mathbf{T}_{s(t)} \rangle \quad \text{(Taste alignment)}
\]

$\lambda = 0.3$ is the adaptation rate. Surprising songs that match your taste increase attention. Boring or disliked songs decrease it.

\subsection{Fatigue Dynamics}

Fatigue increases while listening, decreases during rest:

\[
\boxed{\frac{d\phi}{dt} = \frac{1 - \phi}{\tau_{\text{rise}}} \cdot \mathbbm{1}_{\text{listening}} - \frac{\phi}{\tau_{\text{decay}}} \cdot \mathbbm{1}_{\text{rest}}}
\]

Typical values: $\tau_{\text{rise}} = 20$ minutes, $\tau_{\text{decay}} = 10$ minutes.

\subsection{Choice Model}

At each step, the human selects the next song probabilistically:

\[
\boxed{P(s \mid \mathbf{M}, \mathbf{w}, \phi) = \frac{\exp\left( \frac{\mathcal{U}(s) + \rho \cdot \mathcal{N}(s) - \kappa \cdot \mathcal{F}(s)}{\tau_{\text{choice}}} \right)}{\sum_{s'} \exp\left( \frac{\mathcal{U}(s') + \rho \cdot \mathcal{N}(s') - \kappa \cdot \mathcal{F}(s')}{\tau_{\text{choice}}} \right)}}
\]

where:

\[
\begin{aligned}
\mathcal{U}(s) &= \langle \mathbf{w}, \mathbf{T}_s \rangle \quad &\text{(Taste)} \\
\mathcal{N}(s) &= \|\mathbf{T}_s - \mathbf{M}\| \quad &\text{(Novelty)} \\
\mathcal{F}(s) &= e^{-\|\mathbf{T}_s - \mathbf{M}\|^2} \quad &\text{(Familiarity)} \\
\rho &\in [0,2] \quad &\text{(Novelty-seeking parameter)} \\
\kappa &\in [0,2] \quad &\text{(Familiarity-aversion parameter)} \\
\tau_{\text{choice}} &\in [0.1, 2] \quad &\text{(Decision temperature)}
\end{aligned}
\]

\subsection{Fatigue and Attention Modulation of Choice}

When fatigue is high ($\phi > 0.6$), novelty seeking is penalized:

\[
\tilde{\mathcal{N}}(s) = \mathcal{N}(s) \cdot (1 - \phi)
\]

When attention is low ($\alpha < 0.4$), effective temperature increases:

\[
\tau_{\text{eff}} = \frac{\tau_{\text{choice}}}{\max(0.3, \alpha)}
\]

\subsection{Preference Learning (Bayesian Update)}

After hearing a song and reporting emotion $\mathcal{E} \in [0,10]$, the preference vector updates:

\[
\boxed{\mathbf{w}(t+1) = \mathbf{w}(t) + \eta \cdot \left( \frac{\mathcal{E}(t) - 5}{5} \right) \cdot \mathbf{T}_{s(t)}}
\]

followed by renormalization:

\[
\mathbf{w}(t+1) = \frac{\mathbf{w}(t+1)}{\sum_i w_i(t+1)}
\]

where $\eta = 0.1$ is the learning rate. Hated songs ($\mathcal{E} < 3$) push weights away. Loved songs ($\mathcal{E} > 7$) pull weights toward their features.

\subsection{The Uncapturable Emotion}

The term $\mathcal{E}(t)$ is \textbf{not modeled}. It is input directly by the human:

\[
\mathcal{E}(t) = \text{HumanReport}\big( \text{song } s(t) \big) \in [0,10]
\]

The residual between predicted and actual emotion:

\[
\mathcal{R}(t) = \mathcal{E}(t) - \langle \mathbf{w}(t), \mathbf{P}(t) \rangle
\]

When $\mathcal{R}(t)$ is large, the human says: \textit{"I don't know why, but this song moves me."} That is the part mathematics cannot capture.

\section{Complete Human Traveler Dynamical System}

\[
\boxed{
