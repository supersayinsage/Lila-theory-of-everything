\section{Numerical Implementation}

The system is solved via discrete-time update with time step $\Delta t = 1$ second (or per song for choice steps).

\subsection{Feature Extraction Algorithm}

For each audio file:

\begin{algorithm}
\caption{Feature Extraction}
\begin{algorithmic}
\STATE Load audio $y$, sample rate $sr$
\STATE Compute onset envelope $O(t)$
\STATE $S \gets \frac{\text{mean}(O_{\text{offbeat}})}{\text{mean}(O_{\text{onbeat}})}$
\STATE Detect onset times $\{t_k\}$, compute intervals $\Delta t_k$
\STATE Quantize to 16th notes, compute histogram $p(s)$
\STATE $H \gets -\sum p(s) \log_2 p(s)$
\STATE Compute spectral centroid $\mu(t)$, $\sigma_c \gets \text{std}(\mu(t))$
\STATE Compute chromagram $C(f,t)$, $R \gets \sum_{t,i<j} w_{ij} C_i C_j$
\STATE Compute tempo sequence $\theta(t)$, $C_v \gets \text{std}(\theta)/\text{mean}(\theta)$
\STATE Return $\mathbf{T} = (S, H, \sigma_c, R, C_v)$
\end{algorithmic}
\end{algorithm}

\subsection{Human Traveler Simulation Algorithm}

\begin{algorithm}
\caption{Human Traveler Simulation}
\begin{algorithmic}
\STATE Initialize $\mathbf{M} \gets \mathbf{0}$, $\alpha \gets 0.7$, $\phi \gets 0$, $\mathbf{w} \gets \mathbf{1}/5$
\STATE Choose random first song $s_1$
\FOR{$t = 1$ to $N_{\text{songs}}$}
    \STATE Load $\mathbf{T}_{s_t}$
    \STATE Compute $\beta \gets 1 - \alpha\phi$
    \STATE $\mathbf{P} \gets \beta \mathbf{T}_{s_t} + (1-\beta) \mathbf{M}$
    \STATE $\mathbf{M} \gets \gamma \mathbf{M} + (1-\gamma) \mathbf{T}_{s_t}$
    \STATE $\mathcal{S} \gets \|\mathbf{T}_{s_t} - \mathbf{M}_{\text{old}}\|$
    \STATE $\mathcal{U} \gets \langle \mathbf{w}, \mathbf{T}_{s_t} \rangle$
    \STATE $\alpha \gets \alpha + \lambda(\mathcal{S}\mathcal{U} - \alpha)$
    \STATE $\phi \gets \phi + (1-\phi)/\tau_{\text{rise}} \cdot \Delta t$ (if listening)
    \STATE $\mathcal{E} \gets \text{GetHumanInput}()$
    \STATE $\mathbf{w} \gets \text{renorm}(\mathbf{w} + \eta \cdot \frac{\mathcal{E}-5}{5} \cdot \mathbf{T}_{s_t})$
    \STATE Compute choice probabilities $P(s)$
    \STATE Sample $s_{t+1} \sim P(s)$
\ENDFOR
\end{algorithmic}
\end{algorithm}

