\alpha(t+1) &= \alpha(t) + \lambda \big( \|\mathbf{T}_{s(t)} - \mathbf{M}(t-1)\| \cdot \langle \mathbf{w}(t), \mathbf{T}_{s(t)} \rangle - \alpha(t) \big) \\
\frac{d\phi}{dt} &= \frac{1-\phi}{\tau_{\text{rise}}} \mathbbm{1}_{\text{listening}} - \frac{\phi}{\tau_{\text{decay}}} \mathbbm{1}_{\text{rest}} \\
