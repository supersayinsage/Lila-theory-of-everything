\]

\section{Travel Distance and Trajectory}

The human traveler's path through feature space:

\[
\boxed{\text{Trajectory} = \big\{ \mathbf{P}(t_1), \mathbf{P}(t_2), \dots, \mathbf{P}(t_N) \big\}}
\]

Total perceptual distance traveled:

\[
\boxed{D_{\text{human}} = \sum_{t=1}^{N-1} \|\mathbf{P}(t+1) - \mathbf{P}(t)\|}
\]

Wasserstein distance between genre distributions (post-punk vs punk):

\[
\boxed{W_2(\mathcal{P}_{\text{postpunk}}, \mathcal{P}_{\text{punk}}) = \inf_{\gamma} \left( \int \|\mathbf{T}_p - \mathbf{T}_q\|^2 \, d\gamma(p,q) \right)^{1/2}}
\]

\section{Subgenre Classification}

Let subgenre labels $g \in \{\text{gothic, dance-punk, art-punk, coldwave, general}\}$.

The traveler's subgenre occupation over time:

\[
\boxed{\pi_g(t) = \frac{\sum_{\tau=1}^t \mathbbm{1}[g(s(\tau)) = g]}{t}}
\]

Transition probability between subgenres:

\[
\boxed{P(g \to h) = \frac{\#\{t: g(s(t)) = g,\; g(s(t+1)) = h\}}{\#\{t: g(s(t)) = g\}}}
\]

\section{Time-Varying Features (Within-Song Travel)}

A song is not constant. Let $\mathbf{T}_s(\tau)$ be features at time $\tau$ within the song (e.g., per 10-second window). Then the traveler moves \textit{within} the song:

\[
\frac{d\mathbf{P}}{d\tau} = \big(1 - \alpha\phi\big) \frac{d\mathbf{T}_s}{d\tau} + \alpha\phi \frac{d\mathbf{M}}{d\tau}
\]

