\section{Inflationary Sector and Primordial Observables}

\begin{definition}[Inflationary Potential]
To connect the Wheeler--DeWitt minisuperspace potential


\[
V(a) = a^2 - \Lambda a^4 + \cdots
\]


to observable primordial perturbations, we introduce an effective
inflaton field $\varphi$ with potential
\begin{equation}
V(\varphi)
=
V_0\left(1 - e^{-\sqrt{\frac{2}{3}}\varphi}\right)^2.
\end{equation}
This is the scalar-field representation of the $R^2$ correction
implicit in the $a^4$ term of the minisuperspace potential.
\end{definition}

\begin{definition}[Slow-Roll Parameters]
The slow-roll parameters are defined by
\begin{align}
\epsilon(\varphi)
&=
\frac{1}{2}\left(\frac{V'(\varphi)}{V(\varphi)}\right)^2, \\
\eta(\varphi)
&=
\frac{V''(\varphi)}{V(\varphi)}.
\end{align}
For the potential above, these evaluate to
\begin{align}
\epsilon(\varphi)
&=
\frac{4}{3}
\frac{e^{-2\sqrt{\frac{2}{3}}\varphi}}
{\left(1 - e^{-\sqrt{\frac{2}{3}}\varphi}\right)^2}, \\
\eta(\varphi)
&=
-\frac{4}{3}
\frac{e^{-\sqrt{\frac{2}{3}}\varphi}}
{\left(1 - e^{-\sqrt{\frac{2}{3}}\varphi}\right)}.
\end{align}
\end{definition}

\begin{theorem}[E-fold Relation]
The number of e-folds before the end of inflation is
\begin{equation}
N(\varphi)
\approx
\frac{3}{4}
e^{\sqrt{\frac{2}{3}}\varphi},
\end{equation}
so that
\begin{equation}
e^{-\sqrt{\frac{2}{3}}\varphi}
\approx
\frac{3}{4N}.
\end{equation}
Substituting yields the slow-roll parameters in terms of $N$:
\begin{align}
\epsilon(N) &= \frac{3}{4N^2}, \\
\eta(N) &= -\frac{1}{N}.
\end{align}
\end{theorem}

\begin{theorem}[Primordial Observables]
The scalar spectral index, tensor-to-scalar ratio, and running are
\begin{align}
n_s &= 1 - 6\epsilon + 2\eta
     = 1 - \frac{18}{4N^2} - \frac{2}{N}, \\
r &= 16\epsilon = \frac{12}{N^2}, \\
\alpha_s &= \frac{dn_s}{d\ln k}
         = -\frac{2}{N^2}.
\end{align}
For $N = 50$--$60$, this yields


\[
n_s \approx 0.964,
\qquad
r \approx 0.003,
\qquad
\alpha_s \approx -6\times 10^{-4},
\]


in agreement with Planck 2018.
\end{theorem}

\begin{theorem}[Scalar Amplitude]
The amplitude of scalar perturbations fixes the normalization:
\begin{equation}
A_s
\approx
\frac{V}{24\pi^2 \epsilon}
\approx
2.1\times 10^{-9},
\end{equation}
which determines $V_0$.
\end{theorem}
