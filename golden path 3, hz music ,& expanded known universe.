where $V(a)$ is the effective potential introduced earlier.
\end{definition}

\begin{definition}[Wheeler--DeWitt multiverse manifold]
Define the \emph{Wheeler--DeWitt multiverse manifold} $\mathcal{M}$
as the embedded surface
\begin{equation}
\mathcal{M}
=
\left\{
(a,y,z) \in \mathbb{R}^3
\;\middle|\;
y = V(a),\;
z \in I(a)
\right\},
\end{equation}
where $I(a)$ is an interval (or union of intervals) encoding
distinct cosmological branches (e.g.\ different inflationary
histories or curvature sectors). Each ridge or valley in the
visualization corresponds to a connected component of $I(a)$.
\end{definition}

\begin{definition}[Induced metric]
Equip $\mathcal{M}$ with the metric induced from the Euclidean
metric on $\mathbb{R}^3$:
\begin{equation}
g
=
\iota^\*(\delta),
\end{equation}
where $\iota : \mathcal{M} \hookrightarrow \mathbb{R}^3$ is the
embedding and $\delta$ is the standard Euclidean metric.
In local coordinates $(a,z)$ on $\mathcal{M}$, this yields
\begin{equation}
ds^2
=
\left(1 + V'(a)^2\right)\,da^2
+
2\,V'(a)\,\partial_a z\, da\,dz
+
\left(1 + (\partial_a z)^2\right)\,dz^2,
\end{equation}
with the precise form determined by the choice of $I(a)$.
\end{definition}

\begin{definition}[Golden Path (universe geodesic)]
Let $\gamma : \tau \mapsto (a(\tau), z(\tau))$ be a curve on
$\mathcal{M}$. The \emph{Golden Path} is defined as a geodesic
of $(\mathcal{M}, g)$ satisfying
\begin{equation}
\frac{D^2 \gamma^i}{D\tau^2}
=
\frac{d^2 \gamma^i}{d\tau^2}
+
\Gamma^i_{jk}(\gamma(\tau))
\frac{d\gamma^j}{d\tau}
\frac{d\gamma^k}{d\tau}
= 0,
\end{equation}
with boundary conditions chosen so that the projection of $\gamma$
onto the $a$--axis reproduces the semiclassical FRW evolution
$a(t)$ obtained from the Friedmann equation.
\end{definition}

\begin{theorem}[Consistency with semiclassical cosmology]
There exists a parametrization $\tau(t)$ such that the Golden Path
$\gamma(\tau)$ satisfies
\begin{equation}
\pi_a(\gamma(\tau(t))) = a(t),
\end{equation}
where $\pi_a : \mathcal{M} \to \mathbb{R}$ is the projection onto
the $a$--coordinate and $a(t)$ is the FRW scale factor solving
\begin{equation}
\left(\frac{\dot a}{a}\right)^2
=
\frac{8\pi G}{3}\rho
+
\frac{\Lambda}{3}.
\end{equation}
Thus the classical universe trajectory is realized as a geodesic
on the multiverse manifold $\mathcal{M}$.
\end{theorem}

\begin{definition}[Wave on the manifold]
