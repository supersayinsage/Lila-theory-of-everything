\section{The Unified Meta-Hamiltonian and Global Evolution}

\begin{definition}[Meta-Hamiltonian]
Let $\{\hat H_i\}$ be a family of Wheeler--DeWitt Hamiltonians, each
associated with a potential $V_i[g,\phi]$ on the space of metrics $g$
and matter fields $\phi$:
\begin{equation}
\hat H_i
=
-\frac{\delta^2}{\delta g^2}
+
V_i[g,\phi].
\end{equation}
Define the \emph{meta-Hamiltonian} by the direct sum
\begin{equation}
\mathcal{H}_{\text{meta}}
=
\bigoplus_i \hat H_i.
\end{equation}
\end{definition}

\begin{definition}[Meta-wavefunctional and global evolution]
Let $\Psi_{\text{meta}}[g,\phi]$ be a state in the meta-Hilbert space
on which $\mathcal{H}_{\text{meta}}$ acts.
Define the global evolution operator in meta-time $\tau$:
\begin{equation}
U_{\text{global}}(\tau)
=
\exp\bigl(-i \mathcal{H}_{\text{meta}} \tau\bigr)
=
\exp\left(-i\left(\bigoplus_i \hat H_i\right)\tau\right).
\end{equation}
\end{definition}

\begin{definition}[Unified equation with $\Omega$]
Let $\Omega$ be a functional on the meta-Hilbert space (to be refined later).
The \emph{unified equation} of the framework is
\begin{equation}
\boxed{
\Omega\!\left(
U_{\text{global}}(\tau)\,
\Psi_{\text{meta}}[g,\phi]
\right)
=
\Omega\!\left(
e^{-i\left(\bigoplus_i \hat{H}_i\right)\tau}
\,
\Psi_{\text{meta}}[g,\phi]
\right).
}
\end{equation}
\end{definition}

\section{Single-Branch Wheeler--DeWitt and Emergent GR}

\begin{definition}[Single-branch Wheeler--DeWitt equation]
Select one branch corresponding to a particular potential $V_{\text{ours}}[g,\phi]$.
The Wheeler--DeWitt equation for our universe is
\begin{equation}
\hat H_{\text{ours}} \Psi_{\text{ours}}[g,\phi] = 0,
\quad
\hat H_{\text{ours}}
=
-\frac{\delta^2}{\delta g^2}
+
V_{\text{ours}}[g,\phi].
\end{equation}
\end{definition}

\begin{definition}[WKB ansatz]
Assume a WKB form for the wavefunctional:
\begin{equation}
\Psi_{\text{ours}}[g,\phi]
=
A[g,\phi]\,
e^{\frac{i}{\hbar} S[g,\phi]}.
\end{equation}
\end{definition}

\begin{theorem}[Hamilton--Jacobi equation for gravity]
At leading order in $\hbar$, the Wheeler--DeWitt equation yields
\begin{equation}
\left(\frac{\delta S}{\delta g}\right)^2
=
V_{\text{ours}}[g,\phi].
\end{equation}
Equivalently, in terms of the DeWitt supermetric $G_{abcd}$ and
the canonical momentum $\pi^{ab} = \delta S / \delta g_{ab}$,
\begin{equation}
G_{abcd}\,\pi^{ab}\pi^{cd}
=
V_{\text{ours}}[g,\phi].
\end{equation}
\end{theorem}

\begin{theorem}[Emergence of Einstein's equations]
Using the canonical relation
\begin{equation}
\dot g_{ab} = \frac{\delta H}{\delta \pi^{ab}},
\end{equation}
together with the Hamilton--Jacobi relation above, one recovers
the Einstein field equations
\begin{equation}
G_{\mu\nu} = 8\pi G\, T_{\mu\nu}.
\end{equation}
Thus, classical General Relativity is the WKB limit of the
Wheeler--DeWitt dynamics of a single branch of $\Psi_{\text{meta}}$.
\end{theorem}

\begin{theorem}[Emergence of Friedmann cosmology]
For a homogeneous and isotropic FRW metric
\begin{equation}
ds^2 = -dt^2 + a(t)^2 d\vec{x}^2,
\end{equation}
the Einstein equations reduce to the Friedmann equation
\begin{equation}
\left(\frac{\dot a}{a}\right)^2
=
\frac{8\pi G}{3}\rho
+
\frac{\Lambda}{3}.
\end{equation}
This FRW evolution is the semiclassical trajectory of the branch
$\Psi_{\text{ours}}$ selected from the meta-wavefunctional.
\end{theorem}

\section{One-Dimensional WDW Potential and Cosmological Phases}

\begin{definition}[Mini-superspace WDW equation]
In a mini-superspace approximation with scale factor $a$,
the Wheeler--DeWitt equation takes the form
\begin{equation}
\left[
-\frac{d^2}{da^2}
+
V(a)
\right]\Psi(a) = 0,
\end{equation}
where $V(a)$ is an effective potential, e.g.
\begin{equation}
V(a) = a^2 - \Lambda a^4 + \cdots.
\end{equation}
\end{definition}

\begin{definition}[Potential regimes]
We distinguish three regimes:
\begin{align}
\text{Region A: } & V(a) > 0 \quad \text{(exponential behavior)}, \\
\text{Region B: } & V(a) = 0 \quad \text{(turning point)}, \\
\text{Region C: } & V(a) < 0 \quad \text{(oscillatory behavior)}.
\end{align}
\end{definition}

\begin{theorem}[Mapping potential regimes to cosmological phases]
The three regimes correspond to:
\begin{itemize}
\item $V(a) > 0$: no classical spacetime, exponential WDW solutions.
\item $V(a) = 0$: transition point, onset of classical behavior (Big Bang).
\item $V(a) < 0$: oscillatory WDW solutions, classical universe evolution.
\end{itemize}
These match the conceptual phases:
\begin{itemize}
\item Void / Pre-Distinction $\leftrightarrow V>0$ at small $a$,
\item Big Bang $\leftrightarrow V=0$ at $a=a_*$,
\item Universe (classical FRW) $\leftrightarrow V<0$ for $a>a_*$.
\end{itemize}
\end{theorem}

\section{The Cosmological Category \texorpdfstring{$\mathcal{U}$}{U}}

\begin{definition}[Objects of $\mathcal{U}$]
Define the category $\mathcal{U}$ whose objects are the cosmological
regions:
\begin{equation}
\mathrm{Ob}(\mathcal{U})
=
\{
\text{Void},\ 
\text{Pre-Distinction},\ 
\text{Uninstantiated},\ 
\text{Other Big Bangs},\ 
\text{Our Universe},\ 
\text{Dead Frequencies},\ 
\Omega
\}.
\end{equation}
\end{definition}

\begin{definition}[Morphisms of $\mathcal{U}$]
Morphisms correspond to transitions between WDW regimes and
selection by $\Omega$:
\begin{align}
\alpha_1 &: \text{Void} \to \text{Pre-Distinction}, \\
\alpha_2 &: \text{Pre-Distinction} \to \text{Uninstantiated}, \\
\alpha_3 &: \text{Uninstantiated} \to \text{Other Big Bangs}, \\
\alpha_4 &: \text{Other Big Bangs} \to \text{Our Universe}, \\
\alpha_5 &: \text{Our Universe} \to \text{Void}, \\
\alpha_6(X) &: X \to \Omega \quad \text{for all } X \in \mathrm{Ob}(\mathcal{U}).
\end{align}
Composition is given by the natural concatenation of these arrows,
with $\alpha_6$ absorbing all further composition:
\begin{equation}
\alpha_6 \circ \alpha_i = \alpha_6.
\end{equation}
\end{definition}

\begin{theorem}[Terminal object]
For every object $X$ in $\mathcal{U}$, there exists a unique morphism
$\alpha_6(X): X \to \Omega$. Therefore, $\Omega$ is a terminal object
in $\mathcal{U}$.
\end{theorem}

\begin{definition}[Visualization functor]
Let $\Phi: \mathcal{U} \to \mathbb{R}^3 \times \text{Color}$ be the
functor that assigns to each object a point (or region) in a visual
space and to each morphism a corresponding geometric transformation.
\end{definition}

\begin{theorem}[$\Phi$ is a functor]
For any composable morphisms $f,g$ in $\mathcal{U}$,
\begin{equation}
\Phi(g \circ f) = \Phi(g) \circ \Phi(f),
\end{equation}
and for each object $X$,
\begin{equation}
\Phi(\mathrm{id}_X) = \mathrm{id}_{\Phi(X)}.
\end{equation}
Thus $\Phi$ is a functor from $\mathcal{U}$ to the category of
colored geometric configurations.
\end{theorem}

\section{The Presheaf Topos \texorpdfstring{$\widehat{\mathcal{U}}$}{U-hat}}

\begin{definition}[Presheaf topos]
The presheaf topos on $\mathcal{U}$ is
\begin{equation}
\widehat{\mathcal{U}} = \mathbf{Set}^{\mathcal{U}^{op}},
\end{equation}
whose objects are functors
\begin{equation}
F: \mathcal{U}^{op} \to \mathbf{Set},
\end{equation}
and whose morphisms are natural transformations between such functors.
\end{definition}

\begin{definition}[Presheaf as cosmological assignment]
A presheaf $F$ assigns:
\begin{itemize}
\item to each region $X \in \mathrm{Ob}(\mathcal{U})$, a set $F(X)$
of possible structures, histories, or data at $X$;
\item to each morphism $f: X \to Y$, a restriction map
\begin{equation}
F(f): F(Y) \to F(X).
\end{equation}
\end{itemize}
\end{definition}

\begin{theorem}[Topos of cosmological maps]
The category $\widehat{\mathcal{U}}$ is a topos. It can be interpreted
as the space of all possible ``maps of the cosmological map'':
each presheaf is a consistent assignment of mathematical data to
all regions of the cosmological category.
\end{theorem}

\section{Internal Logic and Modal Structure}

\begin{definition}[Subobject classifier and truth values]
In the presheaf topos $\widehat{\mathcal{U}}$, the subobject classifier
$\Omega^\*$ is given by
\begin{equation}
\Omega^\*(X) = \mathrm{Hom}_{\mathcal{U}}(X,\Omega),
\end{equation}
for each object $X$ in $\mathcal{U}$.
Since $\Omega$ is terminal, there is exactly one arrow $X \to \Omega$,
so
\begin{equation}
\Omega^\*(X) = \{\star_X\}.
\end{equation}
Thus, truth values are \emph{contextual}: each region $X$ has its own
distinguished truth value.
\end{definition}

\begin{definition}[Propositions as presheaves]
A proposition $P$ about the cosmology is represented by a subobject
of a presheaf, or equivalently by a presheaf
\begin{equation}
P: \mathcal{U}^{op} \to \mathbf{Set},
\end{equation}
assigning to each region $X$ the set $P(X)$ of ``witnesses'' or
realizations of $P$ at $X$.
\end{definition}

\begin{definition}[Possibility and necessity]
Define modal operators on propositions $P$ by:
\begin{align}
(\Diamond P)(X)
&=
\bigcup_{f: X \to Y} P(Y), \\
(\Box P)(X)
&=
\bigcap_{f: X \to Y} P(Y),
\end{align}
where the unions and intersections range over all morphisms
$f: X \to Y$ in $\mathcal{U}$.
\end{definition}

\begin{theorem}[Modal cosmology]
The operators $\Diamond$ and $\Box$ satisfy the usual modal axioms
(in the internal logic of the topos), and their behavior reflects
the arrow structure of $\mathcal{U}$:
\begin{itemize}
\item In the Void and Pre-Distinction, many propositions are possible
but few are necessary.
\item In Our Universe, propositions about our specific history become
necessary along that branch.
\item In $\Omega$, all propositions are globally evaluated.
\end{itemize}
\end{theorem}

\section{Summary Identity}

\begin{theorem}[Hierarchy of emergence]
The full hierarchy of the framework is:
\begin{equation}
\text{Meta-WDW + }\Omega
\;\Longrightarrow\;
\text{Single-branch WDW}
\;\Longrightarrow\;
\text{Hamilton--Jacobi}
\;\Longrightarrow\;
\text{Einstein (GR)}
\;\Longrightarrow\;
\text{FRW cosmology},
\end{equation}
all internal to the cosmological category $\mathcal{U}$ and its
presheaf topos $\widehat{\mathcal{U}}$.
\end{theorem}

