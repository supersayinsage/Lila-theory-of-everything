\section{Core Theory}

\subsection{Configuration manifold and metric}

Let $\mathcal{M}$ be a smooth ($C^2$ or better) $n$-dimensional
differentiable manifold. A conscious state at time $t$ is represented by
a point


\[
\bm{s}(t) = (s^1(t),\dots,s^n(t)) \in \mathcal{M}.
\]



Equip $\mathcal{M}$ with a Riemannian metric $g_{ij}(s)$ and inverse
$g^{ij}(s)$:


\[
\|\dot{\bm{s}}\|^2 = g_{ij}(s)\,\dot{s}^i\dot{s}^j,
\qquad
g^{ik}(s)g_{kj}(s)=\delta^i_j.
\]



The Levi--Civita connection is denoted $\nabla_i$, with Christoffel
symbols


\[
\Gamma^i_{\ jk}
=
\tfrac12 g^{i\ell}
\big(
\partial_j g_{\ell k}
+\partial_k g_{\ell j}
-\partial_\ell g_{jk}
\big).
\]



%------------------------------------------------------------
\subsection{IEC functionals}

Define three smooth functionals:


\[
F_I:\mathcal{M}\to\mathbb{R}^p,\qquad
F_E:\mathcal{M}\to\mathbb{R}^q,\qquad
F_C^{\text{geom}}:\mathcal{M}\to\mathbb{R}^r.
\]



These encode information, energetic, and geometric causal structure.

\paragraph{Local template.}


\[
(F_I)_\alpha(s)=f_\alpha(s),\qquad f_\alpha\in C^2(\mathcal{M}).
\]



\paragraph{Controlled nonlocal template.}


\[
(F_I)_\alpha(s)
=
\int_{\mathcal{M}}
K_\alpha(s,s')\,\rho(s')\,d\mu_g(s'),
\]


with $K_\alpha$ smooth and decaying faster than $\mathrm{dist}(s,s')^{-m}$.

Analogous constructions apply to $F_E$ and $F_C^{\text{geom}}$.

%------------------------------------------------------------
\subsection{Universal potential}



\[
\Phi(s)=\Phi\big(F_I(s),F_E(s),F_C^{\text{geom}}(s)\big),
\qquad
\Phi\in C^2(\mathcal{M}).
\]



We adopt the convention that $\Phi$ has units of energy.

%------------------------------------------------------------
\subsection{Deterministic dynamics}



\[
\mathcal{S}_{\text{core}}
=
\int dt\,
\left(
\tfrac12 g_{ij}(s)\dot{s}^i\dot{s}^j
-\Phi(s)
\right).
\]



Euler--Lagrange:


\[
\ddot{s}^i
+
\Gamma^i_{\ jk}\dot{s}^j\dot{s}^k
=
-\,g^{ij}\partial_j\Phi(s).
\]



Gradient flow:


\[
\dot{s}^i
=
-\,g^{ij}(s)\,\partial_j\Phi(s).
\]



%------------------------------------------------------------
\subsection{Stochastic dynamics}



\[
ds^i_t
=
-\,g^{ij}(s_t)\,\partial_j\Phi(s_t)\,dt
+
\Sigma^i_{\ \alpha}(s_t)\,dW^\alpha_t.
\]



Diffusion tensor:


\[
D^{ij}(s)
=
\sum_\alpha
\Sigma^i_{\ \alpha}(s)\,\Sigma^j_{\ \alpha}(s).
\]



Fokker--Planck:


\[
\partial_t\rho
=
\nabla_s\cdot\big(\rho\,g^{ij}\partial_j\Phi\big)
+
\tfrac12
\nabla_s\cdot\big(D^{ij}\nabla_j\rho\big).
\]



%------------------------------------------------------------
\subsection{Hamiltonian structure}



\[
p_i = g_{ij}(s)\,\dot{s}^j,
\qquad
H(s,p)
=
\tfrac12 g^{ij}(s)\,p_ip_j
+
\Phi(s).
\]



Hamilton’s equations:


\[
\dot{s}^i = g^{ij}p_j,
\qquad
\dot{p}_i
=
-\tfrac12\partial_i g^{jk}\,p_jp_k
-\partial_i\Phi(s).
\]



%------------------------------------------------------------
\subsection{Substrate mapping}



\[
\varphi_X:\mathrm{StateSpace}(X)\to\mathcal{M},
\qquad
\bm{s}_X(t)=\varphi_X(\text{state of }X\text{ at }t).
\]



