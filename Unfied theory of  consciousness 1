def grad_Phi(s):
    g = np.zeros(n)
    for i in range(m):
        diff = s - mu[i]
        e = np.exp(-np.dot(diff, diff) / (2 * sigma[i]**2))
        g += alpha[i] * e * diff / sigma[i]**2
    return g + 2 * beta * s

def simulate_sde(s0, dt, steps, Sigma):
    s = np.array(s0, dtype=float)
    traj = [s.copy()]
    for _ in range(steps):
        drift = -grad_Phi(s)
        noise = Sigma @ normal(size=Sigma.shape[1])
        s = s + drift * dt + noise * np.sqrt(dt)
        traj.append(s.copy())
    return np.array(traj)
